{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dimpact:json/v1/diff/default",
  "title": "dimpact diff schema: default",
  "description": "Concrete schema for the `diff -f json` output surface.",
  "$comment": "S1-8 concrete schema for diff/default.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_schema",
    "json_schema",
    "data"
  ],
  "properties": {
    "_schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "const": "dimpact:json/v1/diff/default"
        }
      }
    },
    "json_schema": {
      "type": "string",
      "const": "resources/schemas/json/v1/diff/default.schema.json"
    },
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file_changes"
      },
      "description": "Concrete schema for the `diff -f json` output surface."
    }
  },
  "x-dimpact": {
    "status": "concrete",
    "profile": "diff/default",
    "schema_path": "resources/schemas/json/v1/diff/default.schema.json"
  },
  "$defs": {
    "change_kind": {
      "type": "string",
      "enum": [
        "added",
        "removed",
        "context"
      ]
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "old_line",
        "new_line",
        "content"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/change_kind"
        },
        "old_line": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "new_line": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "content": {
          "type": "string"
        }
      }
    },
    "file_changes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "old_path",
        "new_path",
        "changes"
      ],
      "properties": {
        "old_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "new_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "changes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/change"
          }
        }
      }
    }
  }
}
